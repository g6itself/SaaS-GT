# ─── Dockerfile Node.js – Mode Développement ─────────────────────────────────
# Node.js LTS latest (tag lts pointe toujours sur la dernière LTS stable)
FROM node:24-alpine

# ── Dépendances système (Alpine uses apk) ─────────────────────────────────────
RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    curl

WORKDIR /app

# ── Pré-cache des dépendances npm ─────────────────────────────────────────────
COPY package*.json ./
RUN npm install

EXPOSE 3000

CMD ["npm", "run", "dev"]
