# ─── Dockerfile Rust + Leptos – Mode Developpement ────────────────────────────
FROM rust:latest

# Dependances systeme
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    libpq-dev \
    curl \
    git \
    nodejs \
    npm \
    && rm -rf /var/lib/apt/lists/*

# Cible WASM pour Leptos frontend
RUN rustup target add wasm32-unknown-unknown

# cargo-leptos : build tool pour Leptos (compile server + WASM)
RUN cargo install cargo-leptos --locked

# sqlx-cli : migrations PostgreSQL
RUN cargo install sqlx-cli --no-default-features --features postgres

# sass pour la compilation des styles
RUN npm install -g sass

WORKDIR /app

# Pre-compile les dependances
COPY Cargo.toml Cargo.lock* ./
RUN mkdir src && echo 'fn main() {}' > src/main.rs && echo '' > src/lib.rs \
    && cargo build 2>/dev/null || true \
    && rm -rf src

EXPOSE 3000 3001

CMD ["cargo", "leptos", "watch"]
