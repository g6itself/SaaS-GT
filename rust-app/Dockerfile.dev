# ─── Dockerfile Rust + Leptos – Mode Développement ──────────────────────────
# Rust latest + Node.js LTS latest (via NodeSource)
FROM rust:latest

# ── Dépendances système ──────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    libpq-dev \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# ── Node.js LTS latest via NodeSource ───────────────────────────────────────
RUN curl -fsSL https://deb.nodesource.com/setup_lts.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# ── Cibles Rust ─────────────────────────────────────────────────────────────
RUN rustup target add wasm32-unknown-unknown

# ── Outils Cargo (installés séparément pour le cache Docker) ────────────────
RUN cargo install cargo-leptos --locked
RUN cargo install sqlx-cli --no-default-features --features postgres
RUN cargo install cargo-watch

# ── Sass (compilation styles) ───────────────────────────────────────────────
RUN npm install -g sass

WORKDIR /app

# Note : les sources sont montées en volume (./rust-app:/app)
# Le pré-cache Cargo est omis — il nécessite Cargo.toml qui n'existe
# pas encore dans le contexte de build (fichier monté au runtime).

EXPOSE 3000 3001

CMD ["cargo", "leptos", "watch"]
