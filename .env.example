# Copier ce fichier en .env et adapter les valeurs
# cp .env.example .env

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=devuser
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=devdb

# ─── pgAdmin ──────────────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@dev.local
PGADMIN_PASSWORD=CHANGE_ME

# ─── Application Rust ─────────────────────────────────────────────────────────
DATABASE_URL=postgres://devuser:CHANGE_ME@postgres:5432/devdb
RUST_LOG=debug
RUST_BACKTRACE=1

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-a-strong-random-string
JWT_EXPIRATION_HOURS=24

# ─── Steam API ────────────────────────────────────────────────────────────────
# Obtenir une cle sur : https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your-steam-api-key

# ─── GOG (optionnel, experimental) ───────────────────────────────────────────
GOG_CLIENT_ID=
GOG_CLIENT_SECRET=

# ─── Epic Games (optionnel, acces limite) ────────────────────────────────────
EPIC_CLIENT_ID=
EPIC_CLIENT_SECRET=

# ─── Leptos ───────────────────────────────────────────────────────────────────
LEPTOS_SITE_ADDR=0.0.0.0:3000
LEPTOS_SITE_ROOT=target/site

# ─── URL publique de l'application (utilisée pour les callbacks OAuth/OpenID) ─
# En développement : http://localhost:3100 (port exposé par le service node-app)
# En production    : https://votre-domaine.com
APP_BASE_URL=http://localhost:3100

# ─── Application Node.js (conservee pour transition) ─────────────────────────
NODE_ENV=development
PORT=3000
