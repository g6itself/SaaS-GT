# ─── Template .env.prod — Environnement de Production ────────────────────────
# 1. Copier : cp .env.prod.example .env.prod
# 2. Remplir TOUTES les valeurs marquées CHANGE_ME
# 3. Ne jamais committer .env.prod dans git (déjà dans .gitignore)

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=gtuser
POSTGRES_PASSWORD=CHANGE_ME         # openssl rand -base64 32
POSTGRES_DB=glorioustrophee

# ─── Application Rust ─────────────────────────────────────────────────────────
DATABASE_URL=postgres://gtuser:CHANGE_ME@postgres:5432/glorioustrophee
RUST_LOG=warn

# ─── JWT (secret de signature des tokens) ─────────────────────────────────────
# Générer : openssl rand -hex 64
JWT_SECRET=CHANGE_ME
JWT_EXPIRATION_HOURS=24

# ─── Chiffrement AES-256-GCM (clés API utilisateurs) ─────────────────────────
# Générer : openssl rand -hex 32   (DOIT faire exactement 64 caractères hex)
ENCRYPTION_KEY=CHANGE_ME

# ─── Steam API ────────────────────────────────────────────────────────────────
STEAM_API_KEY=CHANGE_ME

# ─── URL publique (callbacks OAuth/OpenID Steam) ──────────────────────────────
APP_BASE_URL=https://VOTRE_DOMAINE

# ─── Leptos SSR ───────────────────────────────────────────────────────────────
LEPTOS_SITE_ADDR=0.0.0.0:3000
LEPTOS_SITE_ROOT=target/site

# ─── Node.js ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://VOTRE_DOMAINE
